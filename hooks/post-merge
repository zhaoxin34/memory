#!/bin/bash
# Post-merge hook: run make install-tool after merge/pull

echo "Running post-merge hook..."

# Check if there's a Makefile
if [ ! -f "Makefile" ]; then
    echo "Makefile not found, skipping install-tool"
    exit 0
fi

echo "Running make install-tool..."
make install-tool

echo "Post-merge hook completed!"
